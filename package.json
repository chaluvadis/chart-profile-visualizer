{
  "name": "chart-profile-visualizer",
  "displayName": "Chart Profile Visualizer",
  "description": "Visualize Helm charts across environments with value merging and template rendering",
  "version": "0.0.1",
  "publisher": "nomad-in-code",
  "repository": {
    "type": "git",
    "url": "https://github.com/chaluvadis/chart-profile-visualizer.git"
  },
  "bugs": {
    "url": "https://github.com/chaluvadis/chart-profile-visualizer/issues"
  },
  "engines": {
    "vscode": "^1.109.0",
    "node": ">=24.0.0"
  },
  "categories": [
    "Other",
    "Visualization",
    "Programming Languages",
    "Debuggers",
    "Linters"
  ],
  "activationEvents": [
    "workspaceContains:**/Chart.yaml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "chartProfiles",
          "name": "Chart Profiles"
        }
      ]
    },
    "commands": [
      {
        "command": "chartProfiles.refreshCharts",
        "title": "Refresh Charts",
        "icon": "$(refresh)"
      },
      {
        "command": "chartProfiles.viewRenderedYaml",
        "title": "View Rendered YAML"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "chartProfiles.refreshCharts",
          "when": "view == chartProfiles",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "package": "pnpm compile && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^10.0.0",
    "@types/js-yaml": "^4.0.9",
    "typescript-eslint": "^8.55.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3",
    "@vscode/vsce": "^3.7.1"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  },
  "license": "MIT"
}
